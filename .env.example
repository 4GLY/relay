RELAY_ADDR=:8080

# For Neon production use, prefer the direct Postgres connection string.
# Example:
# postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
RELAY_DATABASE_URL=

# Required to start relay-api locally or in deployment.
RELAY_API_TOKEN=
RELAY_BASE_URL=

# Issued client token for normal API and MCP use.
RELAY_CLIENT_TOKEN=

# Optional compatibility alias for MCP consumers.
RELAY_MCP_TOKEN=
