RELAY_ADDR=:8080

# For Neon production use, prefer the direct Postgres connection string.
# Example:
# postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
RELAY_DATABASE_URL=

# Preferred bootstrap admin token for relay-api locally or in deployment.
RELAY_ADMIN_TOKEN=

# Legacy bootstrap fallback for relay-api and compatibility with older tooling.
RELAY_API_TOKEN=
RELAY_BASE_URL=

# Issued client token for normal API and MCP use.
RELAY_CLIENT_TOKEN=

# Optional compatibility alias for MCP consumers.
RELAY_MCP_TOKEN=

# OAuth providers for the V2 end-user surface (cookie sessions).
# GitHub: register an OAuth app at https://github.com/settings/developers
# and set the callback to {RELAY_OAUTH_REDIRECT_BASE_URL}/v1/auth/github/callback.
RELAY_GITHUB_OAUTH_CLIENT_ID=
RELAY_GITHUB_OAUTH_CLIENT_SECRET=

# Google: configure an OAuth 2.0 Client ID in the Google Cloud Console
# (https://console.cloud.google.com/apis/credentials) with the redirect
# {RELAY_OAUTH_REDIRECT_BASE_URL}/v1/auth/google/callback.
RELAY_GOOGLE_OAUTH_CLIENT_ID=
RELAY_GOOGLE_OAUTH_CLIENT_SECRET=

# Public origin used to build OAuth redirect_uri values. Falls back to RELAY_BASE_URL
# when empty. Example for local dev: http://localhost:8080
RELAY_OAUTH_REDIRECT_BASE_URL=
