{
  "name": "relay-web",
  "version": "0.0.0",
  "private": true,
  "description": "Relay V2 end-user web surface — Next.js + Tailwind v4 + shadcn + Framer Motion.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "design:lint": "design.md lint --format json ../DESIGN.md",
    "design:spec": "design.md spec --rules",
    "design:export:tailwind": "design.md export --format tailwind ../DESIGN.md",
    "typecheck": "tsc --noEmit",
    "qa:e2e": "playwright test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.0",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@google/design.md": "^0.1.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.16.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
