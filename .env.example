RELAY_ADDR=:8080

# For Neon production use, prefer the direct Postgres connection string.
# Example:
# postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
RELAY_DATABASE_URL=

# Optional locally, but required for any public API deployment.
RELAY_API_TOKEN=

# MCP defaults.
RELAY_MCP_TRANSPORT=stdio
RELAY_MCP_ADDR=:8091
RELAY_MCP_PATH=/mcp
RELAY_MCP_TOKEN=
