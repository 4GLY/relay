RELAY_ADDR=:8080

# For Neon production use, prefer the direct Postgres connection string.
# Example:
# postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
RELAY_DATABASE_URL=

# Optional locally, but required for any public API deployment.
RELAY_API_TOKEN=
RELAY_BASE_URL=

# Optional client-side convenience variable for MCP examples and consumers.
# The server now accepts the same bearer policy on /mcp as on /v1/*.
RELAY_MCP_TOKEN=
